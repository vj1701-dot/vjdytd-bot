# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash

# Admin Configuration
ADMIN_IDS=123456789,987654321
AUTO_APPROVE=false

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Database Configuration
DATABASE_URL=sqlite:///./bot_data.db

# JDownloader Configuration
JDOWNLOADER_HOST=jdownloader
JDOWNLOADER_PORT=3129
JDOWNLOADER_EMAIL=your_jdownloader_email
JDOWNLOADER_PASSWORD=your_jdownloader_password
JDOWNLOADER_DEVICE_NAME=TelegramBot

# FastAPI Service
FASTAPI_HOST=fastapi-service
FASTAPI_PORT=8000

# File Handling
MAX_FILE_SIZE_TELEGRAM=2147483648
MIN_FILE_SIZE=52428800
DOWNLOAD_PATH=/downloads
TEMP_PATH=/downloads/temp
FILE_RETENTION_HOURS=48

# External Upload Services
GOFILE_API_TOKEN=
UPLOAD_FALLBACK_ENABLED=true

# Rate Limiting
MAX_CONCURRENT_DOWNLOADS_PER_USER=2
GLOBAL_RATE_LIMIT=10

# Logging
LOG_LEVEL=INFO
LOG_FILE=/logs/bot.log

# Optional: Local Telegram Bot API
USE_LOCAL_BOT_API=false
LOCAL_BOT_API_URL=http://telegram-bot-api:8081

# Optional: MTProto
USE_MTPROTO=false
MTPROTO_SESSION_STRING=

# Worker Configuration
CLEANUP_INTERVAL_MINUTES=60
